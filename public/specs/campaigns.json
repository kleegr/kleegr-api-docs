{
  "openapi": "3.0.0",
  "info": {"title": "Campaigns API", "description": "Kleegr Campaigns API", "version": "1.0"},
  "servers": [{"url": "https://services.leadconnectorhq.com"}],
  "tags": [{"name": "Campaigns"}],
  "paths": {
    "/campaigns/": {
      "get": {
        "operationId": "get-campaigns",
        "summary": "Get Campaigns",
        "tags": ["Campaigns"],
        "security": [{"bearer": ["campaigns.readonly"]}],
        "parameters": [
          {"name": "Version", "in": "header", "required": true, "schema": {"type": "string", "enum": ["2021-07-28"]}},
          {"name": "locationId", "required": true, "in": "query", "schema": {"type": "string"}},
          {"name": "status", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Success"},
          "401": {"description": "Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {"bearer": {"scheme": "bearer", "bearerFormat": "JWT", "name": "Authorization", "in": "header", "type": "http"}}
  }
}