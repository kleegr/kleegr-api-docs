            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "vatId": {
            "type": "string",
            "description": "VAT ID",
            "example": "VAT123"
          },
          "updatedAt": {
            "type": "string",
            "description": "Updated at timestamp",
            "example": "2024-06-16T00:00:00.000Z"
          },
          "w8Form": {
            "type": "string",
            "description": "W8 form URL"
          },
          "w9Form": {
            "type": "string",
            "description": "W9 form URL"
          },
          "lastUpdatedBy": {
            "type": "object",
            "description": "Last updated by audit info"
          },
          "email": {
            "type": "string",
