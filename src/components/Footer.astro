---
<footer class="kleegr-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <svg width="20" height="20" viewBox="0 0 32 32" fill="none">
        <rect width="32" height="32" rx="8" fill="#5b3de8"/>
        <path d="M8 16l5-6 3 3 6-7v3l-6 7-3-3-5 6v-3z" fill="white"/>
      </svg>
      <span>Kleegr Developers</span>
    </div>
    <nav class="footer-links">
      <a href="https://kleegr.com">kleegr.com</a>
      <a href="https://crm.kleegr.com">CRM Login</a>
      <a href="/legal/api-attribution">API Attribution</a>
    </nav>
    <p class="footer-legal">
      Kleegr developer integrations are powered by HighLevel APIs.
      Certain technical references are retained for integration accuracy.
    </p>
  </div>
</footer>

<style>
  .kleegr-footer {
    border-top: 1px solid var(--sl-color-hairline);
    padding: 2rem 1.5rem;
    margin-top: 3rem;
  }
  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .footer-links a {
    font-size: 0.82rem;
    color: var(--sl-color-gray-3);
    text-decoration: none;
  }
  .footer-links a:hover {
    color: var(--sl-color-accent);
    text-decoration: underline;
  }
  .footer-legal {
    font-size: 0.75rem;
    color: var(--sl-color-gray-4);
    line-height: 1.5;
  }
</style>
